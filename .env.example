# Frontend URL (for CORS + OAuth2 redirect)
FRONTEND_URL=http://localhost:3000

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# React
REACT_APP_API_URL=http://localhost:8080
